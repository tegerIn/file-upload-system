{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmitOnError": true,
    "sourceMap": true,
    "outDir": "public",
    "rootDir": "client",
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["client/**/*.ts"]
}
