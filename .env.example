DATABASE_URL="file:./dev.db"
JWT_SECRET="replace-with-a-long-random-secret"
# 액세스 JWT 만료(초). 기본 10800=3시간. 만료 후에는 리프레시 토큰으로 연장하거나 다시 로그인합니다.
JWT_ACCESS_TTL_SEC=10800
UPLOAD_DIR="./uploads"
PORT=3000

# --- 메일 발송 (Nodemailer) 미설정 시 인증번호는 서버 터미널에만 출력 ---
# SMTP_PROVIDER: gmail | naver | kakao (카카오메일=다음 SMTP). SMTP_HOST가 있으면 호스트는 그대로 우선.
SMTP_PROVIDER=gmail
# SMTP_HOST=
# SMTP_PORT=
# SMTP_SECURE=false

SMTP_USER=
# 비밀번호: Gmail은 보통 "일반 로그인 비밀번호"가 아니라 Google 계정의 "앱 비밀번호".
# 네이버/카카오는 각 메일 설정의 SMTP(IMAP)용 비밀번호·2단계 앱 비밀번호 등 안내를 따르세요.
SMTP_PASS=

# 표시 이름만 쓰면 자동으로 "이름 <SMTP_USER>" 형태로 발신됩니다.
MAIL_FROM=My-drive
